flowchart LR
    subgraph BEFORE["Before"]
        direction TB
        M_stream["<b>M Stream</b>\n[CLS_M | p1..pN]"]
        P_stream["<b>P Stream</b>\n[CLS_P | p1..pN]"]
    end

    subgraph CORE["CLSExchangeBlock"]
        direction LR
        CAT["Concat\n→ [B, 2, D]"]
        EXCHANGE["<b>Self-Attention</b>\nCLS_M ↔ CLS_P\n+ Residual\n+ MLP + Residual"]
        CAT --> EXCHANGE
    end

    subgraph AFTER["After"]
        direction TB
        M_new["<b>M Stream</b>\n[<b>CLS_M'</b> | p1..pN]\n<i>aware of P</i>"]
        P_new["<b>P Stream</b>\n[<b>CLS_P'</b> | p1..pN]\n<i>aware of M</i>"]
    end

    M_stream -- "CLS_M" --> CAT
    P_stream -- "CLS_P" --> CAT
    EXCHANGE -- "CLS_M'" --> M_new
    EXCHANGE -- "CLS_P'" --> P_new

