# 외부 참고 문서 PDF (벤더 자료 등 — 로컬 전용)
docs/*.pdf

# 외부 codebase clone (submodule 아닌 host-local clone)
external/eai-vc/
external/VideoMAE/

# Claude Code 로컬 설정 (팀 공유 설정 생기면 개별 force add)
.claude/

# 로컬 워크스테이션 전송용 ckpt 번들 (transient, 환경 간 옮길 때만 생성)
*.tar
*.tar.gz

# 사전학습 진행 중 매 epoch 갱신되는 sample image 디렉토리 (요약 PNG만 추적)
paper_artifacts/*_main_train_samples/

# CortexBench 매트릭스 runner의 PID 파일 (잡마다 변경)
paper_artifacts/cortexbench/_logs/_matrix.pid

# CortexBench 집계 csv — derived data. 분산 운영 시 머신마다 자기 결과만 채운 csv가
# 서로 덮어쓰지 않도록 git untrack. git pull 후 `python scripts/eval/aggregate_cortexbench.py
# --root paper_artifacts/cortexbench` 1회면 raw _DONE/log에서 통합 csv 재생성.
paper_artifacts/cortexbench/per_run.csv
paper_artifacts/cortexbench/per_task.csv
paper_artifacts/cortexbench/summary.csv

# CortexBench 잡 산출물 중 무거운 것 (raw _DONE + .hydra + stdout log + job_config.json만 git track)
paper_artifacts/cortexbench/*/*/seed_*/wandb/
paper_artifacts/cortexbench/*/*/seed_*/adroit_cortex_vil/
paper_artifacts/cortexbench/*/*/seed_*/metaworld_cortex_vil/
# 임시 데이터 inspection PNG (루트 일회성 출력 — paper_artifacts/ 또는 docs/preprocessing/로)
calvin_pairs_*.png
libero_pairs_*.png
calvin_inspect_*.png
calvin_motion_dist.png
cortex_*_pairs_*.png
