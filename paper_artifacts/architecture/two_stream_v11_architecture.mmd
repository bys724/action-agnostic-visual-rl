%% Two-Stream v11 — Motion-Guided Attention Routing + Dual-Target
%% ★ 표시 = action probing champion 조합 (A+B+D')의 핵심 representation
%%   - A: M Encoder out
%%   - B: P Encoder out
%%   - D': p_state (motion-routing × 2 후, interpreter_2 전)

flowchart TB
    %% ── Inputs ───────────────────────────────────────────────
    Ft["Frame t"]
    Ftk["Frame t+k"]

    %% ── Preprocessing ────────────────────────────────────────
    Mch["M channel · 3ch<br/>ΔL ⊕ Sobel(ΔL)<br/><i>모션 신호 (시간 변화)</i>"]
    Pch["P channel · 5ch<br/>Sobel(L_t) ⊕ RGB_t<br/><i>의미 신호 (공간 구조)</i>"]

    %% ── Encoders (stream-independent, no CLS exchange) ───────
    subgraph ENC ["Stream-Independent Encoders &nbsp;·&nbsp; no CLS exchange"]
      direction LR
      Menc["<b>★ M Encoder</b><br/>6 Transformer blocks<br/>mask 0.3 · APE<br/><i>모션 센서</i>"]
      Penc["<b>★ P Encoder</b><br/>12 Transformer blocks<br/>mask 0.75 · APE<br/><i>의미 백본 (ViT-Base)</i>"]
    end

    %% ── M decoder ────────────────────────────────────────────
    Mdec["M Decoder<br/>self-attn × 3<br/>+ mask-token inject + dec-APE<br/><i>(loss 없음 — motion field 완성)</i>"]
    Mc(("m_completed<br/><i>완성된 모션 필드<br/>(routing field —<br/>Phase 2의 Q,K source)</i>"))

    %% ── P decoder 3-phase ────────────────────────────────────
    subgraph PDEC ["P Decoder &nbsp;·&nbsp; 3-Phase Dual-Target"]
      direction TB
      P1["<b>Phase 1 · interpreter_1</b><br/>self-attn × 3<br/><i>사전 의미 해석<br/>(pre-motion semantic)</i>"]
      Pst(("p_semantic_t<br/><i>사전 의미 표현<br/>(L_t anchor — downstream 사용 X)</i>"))
      P2["<b>Phase 2 · motion-routing × 2</b><br/>p_state₀ ← p_semantic_t<br/>Q, K ← m_completed · V ← p_state<br/>+ FFN per iter (independent proj.)"]
      Pstate(("<b>★ p_state</b><br/><i>모션 반영 후 P 표현<br/>(motion-routed P)</i>"))
      P3["<b>Phase 3 · interpreter_2</b><br/>self-attn × 3 (non-shared)<br/><i>사후 의미 재해석<br/>(post-motion semantic)</i>"]
      Ptk(("p_semantic_tk<br/><i>최종 P 표현<br/>(future-aware semantic)</i>"))

      P1 --> Pst
      Pst --> P2
      P2 --> Pstate --> P3 --> Ptk
    end

    %% ── Recon head (shared weights, applied twice) & losses ──
    RH_T{{"recon_head<br/>D → ps²·3"}}
    RH_TK{{"recon_head<br/>D → ps²·3"}}
    PredT["pred_t"]
    PredTk["pred_t+k"]
    Lt(["<b>L_t</b> = MSE(pred_t, img_t)<br/><i>masked positions only</i>"])
    Ltk(["<b>L_tk</b> = MSE(pred_t+k, img_t+k)<br/><i>masked positions only</i>"])
    Total(["<b>L_total = L_t + L_tk</b>"])

    %% ── Connections ──────────────────────────────────────────
    Ft --> Mch
    Ftk --> Mch
    Ft --> Pch

    Mch --> Menc
    Pch --> Penc

    Menc --> Mdec --> Mc
    Penc --> P1

    Mc -. "Q, K" .-> P2

    Pst --> RH_T --> PredT --> Lt
    Ptk --> RH_TK --> PredTk --> Ltk
    RH_T <-. "shared weights" .-> RH_TK
    Lt --> Total
    Ltk --> Total

    %% ── Styles ───────────────────────────────────────────────
    %% 색상 의미:
    %%   파란 계열 = M stream (motion)
    %%   초록 계열 = P stream (semantic)
    %%   주황      = Phase 2 motion-routing (M+P 융합 — 핵심 novelty)
    %%   연주황    = 재구성 head & 예측 (output)
    %%   빨강 계열 = loss
    %%   ★ 표시   = downstream 추출 representation (fill 농도 ↑ + stroke 3px)
    classDef input_style fill:#e3f2fd,stroke:#1565C0,color:#000
    classDef m_style fill:#bbdefb,stroke:#1565C0,color:#000
    classDef m_ds fill:#64b5f6,stroke:#0D47A1,color:#000,stroke-width:3px
    classDef p_style fill:#c8e6c9,stroke:#2E7D32,color:#000
    classDef p_ds fill:#81c784,stroke:#1B5E20,color:#000,stroke-width:3px
    classDef route_style fill:#ffcc80,stroke:#E65100,color:#000,stroke-width:2px
    classDef head_style fill:#ffe0b2,stroke:#E65100,color:#000
    classDef loss_style fill:#ef9a9a,stroke:#c62828,color:#000
    classDef total_style fill:#e57373,stroke:#b71c1c,color:#000,stroke-width:2px

    class Ft,Ftk input_style
    class Mch,Mdec,Mc m_style
    class Menc m_ds
    class Pch,P1,P3,Pst,Ptk p_style
    class Penc,Pstate p_ds
    class P2 route_style
    class RH_T,RH_TK,PredT,PredTk head_style
    class Lt,Ltk loss_style
    class Total total_style
